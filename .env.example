# ============================================
# NERAM CLASSES ECOSYSTEM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in the values

# --------------------------------------------
# SUPABASE (Backend Database)
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://db.neramclasses.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# --------------------------------------------
# FIREBASE (Phone/Email Auth for app.neramclasses.com)
# --------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --------------------------------------------
# MICROSOFT ENTRA ID (Auth for nexus & admin)
# --------------------------------------------
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=your-client-id
NEXT_PUBLIC_AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_REDIRECT_URI=https://nexus.neramclasses.com/api/auth/callback/azure-ad

# Microsoft Graph API (for creating users, Teams integration)
MS_GRAPH_CLIENT_ID=your-graph-client-id
MS_GRAPH_CLIENT_SECRET=your-graph-client-secret
MS_GRAPH_TENANT_ID=your-tenant-id

# --------------------------------------------
# RAZORPAY (Payments)
# --------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-secret-key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# --------------------------------------------
# EMAIL (Resend)
# --------------------------------------------
RESEND_API_KEY=re_xxxxx
# Sender address for all transactional emails. Will change to noreply@neramclasses.com after domain transfer.
EMAIL_FROM_ADDRESS=Neram Classes <noreply@neram.co.in>
ADMIN_EMAIL=admin@neramclasses.com
# Secret key for signing unsubscribe tokens in drip emails (min 32 chars, random)
UNSUBSCRIBE_JWT_SECRET=your-random-32-char-secret-here

# --------------------------------------------
# YOUTUBE API (For subscription verification)
# --------------------------------------------
YOUTUBE_API_KEY=your-youtube-api-key
NERAM_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# WHATSAPP (Meta Cloud API - optional)
# --------------------------------------------
# Get these from Meta Business Manager → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# --------------------------------------------
# MICROSOFT TEAMS (Incoming Webhook for notifications)
# --------------------------------------------
TEAMS_WEBHOOK_URL=

# --------------------------------------------
# TAWK.TO (Chat Widget for Marketing Site)
# --------------------------------------------
NEXT_PUBLIC_TAWK_PROPERTY_ID=your-property-id
NEXT_PUBLIC_TAWK_WIDGET_ID=your-widget-id

# --------------------------------------------
# APP CONFIGURATION
# --------------------------------------------
NEXT_PUBLIC_MARKETING_URL=https://neramclasses.com
NEXT_PUBLIC_APP_URL=https://app.neramclasses.com
NEXT_PUBLIC_NEXUS_URL=https://nexus.neramclasses.com
NEXT_PUBLIC_ADMIN_URL=https://admin.neramclasses.com

# --------------------------------------------
# VERCEL (Deployment)
# --------------------------------------------
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID_MARKETING=your-project-id
VERCEL_PROJECT_ID_APP=your-project-id
VERCEL_PROJECT_ID_NEXUS=your-project-id
VERCEL_PROJECT_ID_ADMIN=your-project-id

# --------------------------------------------
# AI Drawing Feedback (Nexus drawing module)
# --------------------------------------------
# Gemini is FREE (15 RPM, 1M tokens/day) — recommended to start
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Anthropic is paid — optional fallback if Gemini key is not set
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --------------------------------------------
# ANALYTICS (Optional)
# --------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# --------------------------------------------
# SEO AUTOMATION
# --------------------------------------------
INDEXNOW_API_KEY=your-indexnow-key
PAGESPEED_API_KEY=your-pagespeed-api-key

# --------------------------------------------
# E2E TESTING (Playwright)
# --------------------------------------------
# Create dedicated test accounts in your STAGING Firebase/Supabase projects.
# Enable Email/Password auth in Firebase Console for these accounts.
# These are only used for automated E2E testing.

# Student test account (Microsoft Entra ID - MFA disabled for E2E)
E2E_TEST_STUDENT_EMAIL=e2etestingstudent@neramclasses.com
E2E_TEST_STUDENT_PASSWORD=change-me

# Teacher test account (Microsoft Entra ID - MFA disabled for E2E)
E2E_TEST_TEACHER_EMAIL=e2etestingteacher@neramclasses.com
E2E_TEST_TEACHER_PASSWORD=change-me

# Admin test account (uses same Microsoft auth as teacher)
E2E_TEST_ADMIN_EMAIL=e2etestingteacher@neramclasses.com
E2E_TEST_ADMIN_PASSWORD=change-me

# Parent test account (read-only access)
E2E_TEST_PARENT_EMAIL=test-parent@neramclasses.com
E2E_TEST_PARENT_PASSWORD=

# Tools App auth testing (Firebase phone + Google)
E2E_TEST_PHONE_NUMBER=+919876543210
E2E_TEST_FIXED_OTP=123456
E2E_TEST_GOOGLE_EMAIL=
E2E_TEST_GOOGLE_PASSWORD=
