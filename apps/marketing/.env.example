# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3011

# Database (optional for marketing site)
# DATABASE_URL=

# API Endpoints (if needed)
# NEXT_PUBLIC_API_URL=http://localhost:3010

# College Outreach (Neram staff admin tool)
# Shared secret to log into /admin/staff-login (rotate manually).
NERAM_STAFF_ADMIN_SECRET=change-me-shared-secret
# HMAC key for signing the staff session cookie (any long random string).
NERAM_STAFF_SESSION_SECRET=change-me-random-hmac-key
# Optional: restrict outreach API to same-origin requests. Leave unset in dev.
# NEXT_PUBLIC_MARKETING_URL=https://neramclasses.com
